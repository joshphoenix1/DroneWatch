# Copy to .env and fill in. The .env file is gitignored and never committed.

# --- HTTP Basic Auth (gates the whole app) ---
# Auth is ENABLED only when BASIC_AUTH_PASS is set. Leave blank for an open server.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=
BASIC_AUTH_REALM=DroneWatch

# --- Server ---
# PORT=5173
# DEFAULT_REGION=lebanon

# --- Notification delivery ---
# NOTIFY_WEBHOOK_URL=https://your-provider-webhook.example
# PUBLIC_BASE_URL=https://your-deployed-app.example

# --- Public reports ---
# REPORT_CONFIRMATION_THRESHOLD=2

# --- Feeds (comma-separated) ---
# CAP_FEEDS=
# OSINT_JSON_FEEDS=
# THREAT_KEYWORDS=
